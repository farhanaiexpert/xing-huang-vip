# Xing Huang — environment variables template
# Copy this file to .env and fill in the values from Replit Secrets / your VPS.
# Never commit .env (or real secrets) to git. Use placeholders only in this file.

# ── API Keys ──────────────────────────────────────────────────────────────────
ODDS_API_KEY=your_odds_api_key
BETSAPI_KEY=your_betsapi_key
API_FOOTBALL_KEY=your_api_football_key

# ── Payments ──────────────────────────────────────────────────────────────────
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret
PLISIO_IPN_SECRET=your_plisio_ipn_secret

# ── Database ──────────────────────────────────────────────────────────────────
# Development (local Postgres)
DATABASE_URL=postgresql://postgres:password@localhost:5432/xinghuang?sslmode=disable
# Production example (do NOT put real credentials here — set on the server only):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ── Frontend build ────────────────────────────────────────────────────────────
# Where the frontend should reach the API (baked in at build time)
VITE_API_BASE_URL=https://your-domain.com

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=your_long_random_session_secret
