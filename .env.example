# =============================================================================
# Xing Huang — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in every value before running Docker.
#
#   cp .env.example .env
#   nano .env
#
# NODE_ENV, PORT, and BASE_PATH are pinned in docker-compose.yml.
# Do NOT add them here — they would conflict.
# Never commit .env (real secrets) to git. Only commit this example file.
# =============================================================================

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Authentication (REQUIRED) ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ── Odds & Sports Data ────────────────────────────────────────────────────────
ODDS_API_KEY=
BETSAPI_KEY=

# ── Payment Gateways ──────────────────────────────────────────────────────────
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
CRYPTOMUS_API_KEY=
CRYPTOMUS_MERCHANT_ID=
PLISIO_API_KEY=
PLISIO_IPN_SECRET=

# ── Deposit Wallet Addresses ──────────────────────────────────────────────────
DEPOSIT_WALLET_ADDRESS=
DEPOSIT_WALLET_ADDRESS_ERC=
DEPOSIT_WALLET_ADDRESS_BSC=
DEPOSIT_WALLET_ADDRESS_BTC=
DEPOSIT_WALLET_ADDRESS_SOL=
DEPOSIT_WALLET_ADDRESS_TON=
DEPOSIT_WALLET_ADDRESS_XRP=

# ── Admin Bootstrap (one-time use — REMOVE after first login) ─────────────────
# Set this to any random string you choose, then visit:
#   http://YOUR_VPS_IP:3000/api/init-admin?token=<your_value>
# Once the admin account is created, delete this line and restart the container.
ADMIN_INIT_TOKEN=
