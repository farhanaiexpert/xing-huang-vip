# =============================================================================
# Xing Huang — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in every value before running Docker.
#
#   cp .env.example .env
#   nano .env
#
# NODE_ENV, PORT, and BASE_PATH are pinned in docker-compose.yml.
# Do NOT add them here — they would conflict.
# Never commit .env (real secrets) to git. Only commit this example file.
# =============================================================================

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Authentication (REQUIRED) ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_64_random_hex_characters

# ── Odds & Sports Data ────────────────────────────────────────────────────────
ODDS_API_KEY=your_odds_api_key
BETSAPI_KEY=your_betsapi_key
API_FOOTBALL_KEY=your_api_football_key

# ── Payment Gateways ──────────────────────────────────────────────────────────
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret
CRYPTOMUS_API_KEY=your_cryptomus_api_key
CRYPTOMUS_MERCHANT_ID=your_cryptomus_merchant_id
PLISIO_API_KEY=your_plisio_api_key
PLISIO_IPN_SECRET=your_plisio_ipn_secret

# ── Deposit Wallet Addresses ──────────────────────────────────────────────────
DEPOSIT_WALLET_ADDRESS=your_trc20_usdt_address
DEPOSIT_WALLET_ADDRESS_ERC=your_erc20_usdt_address
DEPOSIT_WALLET_ADDRESS_BSC=your_bsc_usdt_address
DEPOSIT_WALLET_ADDRESS_BTC=your_btc_address
DEPOSIT_WALLET_ADDRESS_SOL=your_solana_address
DEPOSIT_WALLET_ADDRESS_TON=your_ton_address
DEPOSIT_WALLET_ADDRESS_XRP=your_xrp_address

# ── Admin Bootstrap ───────────────────────────────────────────────────────────
# Visit GET /api/init-admin?token=<value> once to create the super-admin.
# Remove this line and restart the container after the account is created.
ADMIN_INIT_TOKEN=xh2026
