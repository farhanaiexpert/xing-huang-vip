# CupBett — environment variables template
# Copy this file to .env and fill in the values from Replit Secrets.
# Never commit .env to git (it is already in .gitignore).

# ── API Keys ──────────────────────────────────────────────────────────────────
ODDS_API_KEY=
VITE_ODDS_API_KEY=
BETSAPI_KEY=
API_FOOTBALL_KEY=

# ── Payments ──────────────────────────────────────────────────────────────────
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Optional / not yet configured ─────────────────────────────────────────────
CRYPTOMUS_API_KEY=
CRYPTOMUS_MERCHANT_ID=
